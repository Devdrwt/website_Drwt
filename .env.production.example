# =====================================================================
#  PRODUCTION ENV — copy to `.env` on the VPS (next to docker-compose.yml)
#  Never commit the real .env. Generate strong, unique secrets.
# =====================================================================

# --- Container image (set by CI; override to pin a specific tag) ---
APP_IMAGE=ghcr.io/devdrwt/website_drwt:latest

# --- Public domain (used by Caddy for automatic HTTPS) ---
SITE_DOMAIN=drwintech.com

# --- MySQL (the `db` service creates these on first boot) ---
MYSQL_DATABASE=drwintech
MYSQL_USER=drwintech
MYSQL_PASSWORD=change-me-strong-db-password
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

# --- Auth.js / NextAuth ---
# Generate with:  openssl rand -base64 32
AUTH_SECRET=change-me-with-openssl-rand-base64-32

# --- Public site config (also baked at build time via CI build args) ---
NEXT_PUBLIC_SITE_URL=https://drwintech.com
NEXT_PUBLIC_WHATSAPP=+22962707002
NEXT_PUBLIC_CONTACT_EMAIL=contact@drwintech.com
NEXT_PUBLIC_PHONE=+229 01 97 17 17 96
